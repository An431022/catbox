value.shadowDistance.768.0=§4§l§n§o48 区块
value.shadowDistance.1024.0=§4§k-§r§4§l§n§o64 区块§r§4§k-

option.ENTITY_SHADOW=实体阴影
option.ENTITY_SHADOW.comment=启用实体和方块实体投射的阴影。“普通实体”包括动物和怪物，而“完整”选项还包括箱子等方块实体。§c[-]§r 实体阴影对性能的影响往往比预期更大，有时会消耗超过50%的帧率。
value.ENTITY_SHADOW.-1=§a关闭
value.ENTITY_SHADOW.1=§c普通实体
value.ENTITY_SHADOW.2=§4§k-§r§4§l§n§o完整§r§4§k- §r§c[-]

option.DETAIL_QUALITY=细节质量
option.DETAIL_QUALITY.comment=调整若干影响性能的小项：水材质、TAA、光照微调、夜空星云、下界风暴、末地光束、天空反射、雨滴精度、摆动效果、运动模糊。
value.DETAIL_QUALITY.0=§a极低（Potato）
value.DETAIL_QUALITY.2=§e中等
value.DETAIL_QUALITY.3=§c高

option.CLOUD_QUALITY=云质量
option.CLOUD_QUALITY.comment=调整Reimagined/Unbound云样式的光照、细节和采样质量。§e[*]§r 仅在选择“Reimagined”或“Unbound”云样式时生效。
value.CLOUD_QUALITY.0=§a关闭
value.CLOUD_QUALITY.1=§a低
value.CLOUD_QUALITY.2=§e中等
value.CLOUD_QUALITY.3=§c高

option.FXAA_DEFINE=抗锯齿（FXAA）
option.FXAA_DEFINE.comment=启用快速近似抗锯齿（FXAA），使图像更平滑。
value.FXAA_DEFINE.-1=§a关闭
value.FXAA_DEFINE.1=§e开启

option.SSAO_QUALI_DEFINE=边缘阴影（SSAO）质量
option.SSAO_QUALI_DEFINE.comment=调整屏幕空间环境光遮蔽（SSAO）的质量，为场景边缘增加额外的环境阴影。每个档位进一步减少噪点。
value.SSAO_QUALI_DEFINE.0=§a关闭
value.SSAO_QUALI_DEFINE.2=§e中等
value.SSAO_QUALI_DEFINE.3=§c高

option.ANISOTROPIC_FILTER=纹理过滤
option.ANISOTROPIC_FILTER.comment=使用各向异性过滤提高各向异性贴图的质量。§e[*]§r 确保视频设置中的“mipmap levels”设为最大（4）以获得更好效果。
value.ANISOTROPIC_FILTER.0=§a关闭
value.ANISOTROPIC_FILTER.4=§e4x
value.ANISOTROPIC_FILTER.8=§e8x
value.ANISOTROPIC_FILTER.16=§4§l16x

option.COLORED_LIGHTING=高级颜色追踪 §e[*]§r
option.COLORED_LIGHTING.comment=使用体素化和洪泛照明为方块光添加颜色，并引入一些新光源。§e[*]§r 仅在 Iris 和受支持的平台上工作。§e[*]§r 若“实时阴影”为OFF，则此设置将被禁用。§a[+]§r 高级颜色追踪系统还启用其它功能，可在“其他”->“ACT 功能”中单独开关。§c[-]§r 此效果的高区块值对性能的影响超出预期，每次增加可能带来超过两倍的性能损失。§c[-]§r 处理非填充方块或模组方块时可能产生光色泄露问题。
value.COLORED_LIGHTING.0=§a关闭
value.COLORED_LIGHTING.128=§c4 区块
value.COLORED_LIGHTING.192=§c6 区块
value.COLORED_LIGHTING.256=§4§l8 区块
value.COLORED_LIGHTING.384=§4§l12 区块
value.COLORED_LIGHTING.512=§4§l§n§o16 区块
value.COLORED_LIGHTING.768=§4§l§n§o24 区块 §r§c[-]
value.COLORED_LIGHTING.1024=§4§k-§r§4§l§n§o32 区块§r§4§k- §r§c[-]

option.WORLD_SPACE_REFLECTIONS=世界空间反射 §e[*]§r
option.WORLD_SPACE_REFLECTIONS.comment=在世界空间而非屏幕空间计算反射。§e[*]§r 仅在性能设置中启用高级颜色追踪且系统支持时生效。§e[*]§r 此效果的最大距离取决于高级颜色追踪距离，但内部技术上限制为16区块。§c[-]§r 此效果在较高追踪距离下会严重影响性能。§c[-]§r 更换资源包后世界空间反射可能完全失效，但重启游戏可修复。§c[-]§r 在使用高于16x分辨率的模组或资源包时，可能导致强烈闪烁。
value.WORLD_SPACE_REFLECTIONS.-1=§a关闭
value.WORLD_SPACE_REFLECTIONS.1=§4§l§n§o开启

option.WORLD_SPACE_REF_MODE=WSR 模式 §e[*]§r
option.WORLD_SPACE_REF_MODE.comment=决定世界空间反射的运行模式。§e[*]§r “仅 WSR”模式可消除所有屏幕空间反射伪影，但“WSR + SSR”模式能在反射中呈现更多细节，因为屏幕空间反射可以访问屏幕上的所有细节而不受方块或距离限制。
value.WORLD_SPACE_REF_MODE.1=仅 WSR
value.WORLD_SPACE_REF_MODE.2=WSR + SSR

option.SSAO_I=边缘阴影强度（SSAO）
option.SSAO_I.comment=决定屏幕空间环境光遮蔽（SSAO）的强度。§e[*]§r 若在“性能设置”中禁用SSA O则此设置无效。
value.SSAO_I.0=§c关闭

option.VANILLAAO_I=原版环境光强度（Vanilla AO）
option.VANILLAAO_I.comment=决定Minecraft自带环境光（AO）的强度。
value.VANILLAAO_I.0=§c关闭

option.BORDER_FOG=边界雾
option.BORDER_FOG.comment=在已加载世界边缘显示浓雾以隐藏区块边界。§e[*]§r 建议在渲染距离低于8区块时禁用边界雾。

option.ATM_FOG_MULT=大气雾
option.ATM_FOG_MULT.comment=调整基于高度的大气雾强度。
value.ATM_FOG_MULT.0.50=非常细微
value.ATM_FOG_MULT.0.65=细微
value.ATM_FOG_MULT.0.80=正常
value.ATM_FOG_MULT.0.95=浓重

option.ATM_FOG_DISTANCE=大气雾距离
option.ATM_FOG_DISTANCE.comment=调整相机开始出现大气雾的距离。§e[*]§r 注意雾距离也会随视频设置中的渲染距离自动调整。

option.ATM_FOG_ALTITUDE=大气雾高度
option.ATM_FOG_ALTITUDE.comment=决定大气雾最明显出现的高度。

option.CAVE_FOG=洞穴雾
option.CAVE_FOG.comment=在深地下区域启用额外雾效。

option.LIGHTSHAFT_BEHAVIOUR=光柱模式
